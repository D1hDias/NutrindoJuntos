# ============================================
# PAYLOAD CMS - Environment Variables
# ============================================
# Copy this file to .env and fill with your values
# NEVER commit .env to version control

# ============================================
# NODE ENVIRONMENT
# ============================================
# Options: development, production
NODE_ENV=development

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port for Payload CMS server
PORT=3001

# Public URL where Payload will be accessible
# Development: http://localhost:3001
# Production: https://cms.nutrindojuntos.com.br
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# ============================================
# DATABASE (PostgreSQL via Supabase)
# ============================================
# PostgreSQL connection string
# Format: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]
#
# Supabase format:
# postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
#
# Local Docker PostgreSQL format:
# postgresql://nutrindo:nutrindo_dev_password@postgres:5432/nutrindo_juntos
DATABASE_URI=postgresql://postgres:your-password-here@db.xxxxxxxxxxxxx.supabase.co:5432/postgres

# ============================================
# PAYLOAD SECRET
# ============================================
# Secret key for JWT tokens and encryption
# IMPORTANT: Use a strong, random string with at least 32 characters
# Generate one with: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
PAYLOAD_SECRET=your-secret-key-min-32-chars-change-in-production

# ============================================
# CLOUDINARY (Image Storage + CDN)
# ============================================
# Cloudinary Cloud Name (e.g., dxxxxx)
# Get from: https://console.cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name

# Cloudinary API Key (numeric)
CLOUDINARY_API_KEY=123456789012345

# Cloudinary API Secret (alphanumeric)
CLOUDINARY_API_SECRET=your-api-secret-here

# ============================================
# CORS (Optional)
# ============================================
# Allowed origins for CORS (comma-separated)
# Development: http://localhost:3000
# Production: https://nutrindojuntos.com.br,https://www.nutrindojuntos.com.br
PAYLOAD_PUBLIC_CORS=http://localhost:3000

# ============================================
# EMAIL CONFIGURATION (Optional - for Payload forgot password)
# ============================================
# SMTP settings for Payload to send emails (optional)
# If not set, password reset emails won't be sent
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM_NAME=NUTRINDO JUNTOS
# SMTP_FROM_ADDRESS=noreply@nutrindojuntos.com.br

# ============================================
# RATE LIMITING (Optional)
# ============================================
# Maximum number of requests per window
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=15m

# ============================================
# MONITORING (Optional)
# ============================================
# Sentry DSN for CMS error tracking
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Enable verbose logging
# PAYLOAD_DEBUG=true

# Disable telemetry (optional)
# PAYLOAD_TELEMETRY_DISABLED=true

# ============================================
# FASE 2 - PAGAMENTOS (PREPARADO - NÃO ATIVAR AINDA)
# ============================================
# Descomentar quando implementar Fase 2

# Stripe (para webhooks internos)
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx

# Hotmart
# HOTMART_CLIENT_ID=xxxxxxxxxx
# HOTMART_CLIENT_SECRET=xxxxxxxxxx

# ============================================
# FASE 3 - STREAMING (PLANEJADO - NÃO ATIVAR AINDA)
# ============================================
# Descomentar quando implementar Fase 3

# Mux (Video Hosting)
# MUX_TOKEN_ID=xxxxxxxxxx
# MUX_TOKEN_SECRET=xxxxxxxxxx

# Supabase Realtime (para comentários e progresso em tempo real)
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=xxxxxxxxxx

{
  "name": "@nutrindo-juntos/cms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--no-deprecation\" tsx src/server.ts",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation\" payload build",
    "start": "cross-env NODE_OPTIONS=\"--no-deprecation\" NODE_ENV=production node dist/server.js",
    "deploy": "payload build",
    "vercel-build": "payload build",
    "generate:types": "payload generate:types",
    "generate:graphql-schema": "payload generate:graphqlSchema",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "payload": "payload",
    "reset": "tsx scripts/reset-database.ts",
    "postbuild": "echo 'Build completed for Vercel'"
  },
  "dependencies": {
    "@payloadcms/bundler-webpack": "^1.0.7",
    "@payloadcms/db-postgres": "^0.8.7",
    "@payloadcms/plugin-cloud-storage": "^1.1.3",
    "@payloadcms/plugin-seo": "^2.3.3",
    "@payloadcms/richtext-slate": "^1.5.2",
    "cloudinary": "^2.2.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "graphql": "^16.9.0",
    "payload": "^2.8.2",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.17.4",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.3",
    "prettier": "^3.3.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.5.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}

# ==================================
# NUTRINDO JUNTOS - Environment Variables
# ==================================

# ---------------------------------
# FASE 1 - MVP (ATIVO)
# ---------------------------------

# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# Brevo (Email Marketing & CRM)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_LIST_NEWSLETTER=1
BREVO_LIST_LEADS_CURSOS=2
BREVO_LIST_LEADS_MENTORIA=3
BREVO_LIST_CONTATO=4

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ---------------------------------
# FASE 2 - PAGAMENTOS (PREPARADO)
# ---------------------------------

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# Hotmart
HOTMART_CLIENT_ID=xxxxxxxxxx
HOTMART_CLIENT_SECRET=xxxxxxxxxx
HOTMART_WEBHOOK_SECRET=xxxxxxxxxx
HOTMART_PRODUCT_ID_NUTRICAO_ESPORTIVA=123456
HOTMART_PRODUCT_ID_NUTRICAO_CLINICA=789012

# ---------------------------------
# FASE 3 - STREAMING (PLANEJADO)
# ---------------------------------

# Mux (Video Hosting)
MUX_TOKEN_ID=xxxxxxxxxx
MUX_TOKEN_SECRET=xxxxxxxxxx
NEXT_PUBLIC_MUX_ENV_KEY=xxxxxxxxxx

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Supabase (Optional - para Realtime)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxx

# ============================================
# NEXT.JS FRONTEND - Environment Variables
# ============================================
# Copy this file to .env.local and fill with your values
# NEVER commit .env.local to version control

# ============================================
# SITE CONFIGURATION
# ============================================
# Public site URL (without trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# SUPABASE (Database & Backend)
# ============================================
# Supabase Project URL
# Get from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon/Public Key
# Get from: https://app.supabase.com/project/_/settings/api
# This is safe to use in client-side code
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Secret Key (Server-side only - replaces service_role)
# Get from: https://app.supabase.com/project/_/settings/api
# NEVER expose this in client-side code - admin operations only
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-secret-key-here

# ============================================
# BREVO (Email Marketing + CRM)
# ============================================
# Brevo API Key (starts with xkeysib-)
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-your-api-key-here

# Brevo Contact Lists IDs (numeric)
# Get from: https://app.brevo.com/contacts/lists
BREVO_LIST_NEWSLETTER=1
BREVO_LIST_LEADS_CURSOS=2
BREVO_LIST_LEADS_MENTORIA=3
BREVO_LIST_CONTATO=4

# Brevo Email Template IDs (numeric) - Optional
# Get from: https://app.brevo.com/camp/template/listing
BREVO_TEMPLATE_NEWSLETTER_WELCOME=1
BREVO_TEMPLATE_CURSO_CONFIRMACAO=2
BREVO_TEMPLATE_MENTORIA_CONFIRMACAO=3
BREVO_TEMPLATE_CONTATO_CONFIRMACAO=4

# ============================================
# ANALYTICS & MONITORING
# ============================================
# Google Analytics 4 Measurement ID (starts with G-)
# Get from: https://analytics.google.com/
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking (starts with https://)
# Get from: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Sentry Organization Slug (for source maps upload)
# Get from: https://sentry.io/settings/
SENTRY_ORG=your-org-slug

# Sentry Project Name (for source maps upload)
# Get from: https://sentry.io/settings/projects/
SENTRY_PROJECT=your-project-name

# Sentry Auth Token (for CI/CD source maps upload)
# Get from: https://sentry.io/settings/account/api/auth-tokens/
# Required permissions: project:releases, org:read
SENTRY_AUTH_TOKEN=your-auth-token-here

# ============================================
# UPSTASH REDIS (Rate Limiting)
# ============================================
# Upstash Redis REST URL
# Get from: https://console.upstash.com/redis
# Example: https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io

# Upstash Redis REST Token
# Get from: https://console.upstash.com/redis (same page as URL)
# Used automatically by @upstash/redis SDK via Redis.fromEnv()
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
# Enable/disable features for testing
NEXT_PUBLIC_ENABLE_BLOG=true
NEXT_PUBLIC_ENABLE_NEWSLETTER=true
NEXT_PUBLIC_ENABLE_CURSOS=true
NEXT_PUBLIC_ENABLE_MENTORIA=true

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Show debug info in development
# Set to 'true' to enable console logs and debug panels
NEXT_PUBLIC_DEBUG=false

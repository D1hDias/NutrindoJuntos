# .env.production.template
# Copy this to .env.production and fill with your values

# ===================================
# APPLICATION SETTINGS
# ===================================
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://nutrindojuntos.com.br
NEXT_PUBLIC_PAYLOAD_API_URL=https://cms.nutrindojuntos.com.br/api

# ===================================
# DATABASE CONFIGURATION
# ===================================
POSTGRES_DB=nutrindo_juntos_prod
POSTGRES_USER=nutrindo_user
POSTGRES_PASSWORD=your_secure_db_password_here
DATABASE_URL=postgresql://nutrindo_user:your_secure_db_password_here@postgres:5432/nutrindo_juntos_prod

# ===================================
# BREVO EMAIL MARKETING
# ===================================
BREVO_API_KEY=your_brevo_api_key_here
BREVO_LIST_NEWSLETTER=1
BREVO_LIST_LEADS_CURSOS=2
BREVO_LIST_LEADS_MENTORIA=3
BREVO_LIST_CONTATO=4
CONTACT_EMAIL=contato@nutrindojuntos.com.br

# ===================================
# ANALYTICS & MONITORING
# ===================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn-here

# ===================================
# CLOUDINARY (Media Storage)
# ===================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===================================
# REDIS CONFIGURATION
# ===================================
REDIS_URL=redis://redis:6379

# ===================================
# SSL & SECURITY
# ===================================
SSL_CERT_PATH=/etc/ssl/certs/nutrindojuntos.com.br.crt
SSL_KEY_PATH=/etc/ssl/certs/nutrindojuntos.com.br.key

# ===================================
# BACKUP SETTINGS
# ===================================
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
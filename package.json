{
  "name": "nutrindo-juntos",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma Educacional de Nutrição - NUTRINDO JUNTOS",
  "author": "NUTRINDO JUNTOS",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "pnpm --parallel --stream dev",
    "dev:fast": "./scripts/dev-fast.sh",
    "dev:stop": "./scripts/dev-stop.sh",
    "dev:web": "pnpm --filter web dev",
    "dev:cms": "pnpm --filter cms dev",
    "build": "pnpm --filter \"./apps/**\" build",
    "build:web": "pnpm --filter web build",
    "build:cms": "pnpm --filter cms build",
    "build:static": "pnpm --filter web build:static",
    "export:hostinger": "pnpm --filter web export:hostinger",
    "start": "pnpm --parallel --stream start",
    "start:web": "pnpm --filter web start",
    "start:cms": "pnpm --filter cms start",
    "lint": "pnpm --filter \"./apps/**\" lint",
    "type-check": "pnpm --filter \"./apps/**\" type-check",
    "test": "pnpm --filter web test",
    "test:e2e": "pnpm --filter web test:e2e",
    "clean": "pnpm --recursive exec -- rm -rf dist .next node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "deploy:cms": "pnpm --filter cms deploy",
    "deploy:web": "pnpm run build:static && pnpm run export:hostinger"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "typescript": "^5.5.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "pnpm": {
    "overrides": {
      "sharp": "^0.32.6"
    }
  }
}

# ===================================
# NUTRINDO JUNTOS - Environment Variables
# ===================================

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://nutrindojuntos.com.br

# Payload CMS
NEXT_PUBLIC_PAYLOAD_API_URL=https://cms.nutrindojuntos.com.br/api

# Brevo (Email Marketing)
BREVO_API_KEY=xkeysib-your-api-key-here
BREVO_LIST_NEWSLETTER=1
BREVO_LIST_LEADS_CURSOS=2
BREVO_LIST_LEADS_MENTORIA=3
BREVO_LIST_CONTATO=4

# Google Business Profile (Depoimentos)
# Obter em: https://console.cloud.google.com
# API: "Google Business Profile API" (My Business Account Management API)
GOOGLE_BUSINESS_ACCESS_TOKEN=your-access-token-here
GOOGLE_BUSINESS_ACCOUNT_ID=your-account-id-here
GOOGLE_BUSINESS_LOCATION_ID=your-location-id-here

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Error Tracking
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# MCP Hostinger (para deploy automático)
HOSTINGER_API_TOKEN=your-hostinger-api-token-here
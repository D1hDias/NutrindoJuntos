# ============================================
# NUTRINDO JUNTOS - Environment Variables
# ============================================
# IMPORTANTE: Copie este arquivo para .env.local e preencha com valores reais
# NUNCA commite .env.local ao Git!

# ============================================
# GOOGLE AI (Gemini MCP)
# ============================================
# Obtenha em: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================
# FIGMA (Figma MCP)
# ============================================
# Já configurado em .claude/settings.json
# Mas pode adicionar aqui também se preferir
# FIGMA_PERSONAL_ACCESS_TOKEN=figd_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================
# FASE 1 - MVP (ATIVO)
# ============================================

# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Nutrindo Juntos"

# Brevo (Email Marketing)
BREVO_API_KEY=xkeysib-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BREVO_LIST_NEWSLETTER=123
BREVO_LIST_LEADS_CURSOS=124
BREVO_LIST_LEADS_MENTORIA=125
BREVO_LIST_CONTATO=126

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry (Error Tracking)
NEXT_PUBLIC_SENTRY_DSN=https://XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX@sentry.io/XXXXXXX

# ============================================
# PAYLOAD CMS
# ============================================

# Database (Supabase PostgreSQL)
DATABASE_URI=postgresql://user:password@host:5432/database

# Payload
PAYLOAD_SECRET=your-secret-key-here-min-32-characters
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ============================================
# FASE 2 - PAGAMENTOS (PREPARADO - NÃO ATIVAR AINDA)
# ============================================

# Stripe
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Hotmart
# HOTMART_CLIENT_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
# HOTMART_CLIENT_SECRET=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
# HOTMART_BASIC_AUTH=Basic XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# HOTMART_WEBHOOK_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================
# FASE 3 - STREAMING (PLANEJADO - NÃO ATIVAR AINDA)
# ============================================

# Mux (Video Platform)
# MUX_TOKEN_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
# MUX_TOKEN_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# MUX_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# NextAuth.js
# NEXTAUTH_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# NEXTAUTH_URL=http://localhost:3000

# ============================================
# DEVELOPMENT
# ============================================

# Node Environment
NODE_ENV=development

# Debug
DEBUG=false
